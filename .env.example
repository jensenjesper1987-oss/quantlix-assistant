# Local development and reference for required configuration.
# Do not commit real secrets — use Kubernetes Secrets (or a secret manager) in prod.

# --- Quantlix gateway (server-side; never exposed to the browser widget) ---
QUANTLIX_API_KEY=
QUANTLIX_DEPLOYMENT_ID=
QUANTLIX_CONTRACT_ID=support-bot
QUANTLIX_API_BASE=https://api.quantlix.ai

# --- Embeddings + pgvector ---
VOYAGE_API_KEY=
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/quantlix_assistant

# --- Optional (reserved for future session / cache use in this template) ---
REDIS_URL=redis://localhost:6380/0

# --- Optional provider keys (only if your Quantlix deployment routes to them) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- HTTP server ---
# Default 8000 matches production Dockerfile / Kubernetes Service.
# docker-compose overrides to 8001 for local port layout.
PORT=8000

# --- CORS: comma-separated origins allowed to call POST /chat from the browser ---
WIDGET_PUBLIC_ORIGIN=http://localhost:3030,http://localhost:5173

# =============================================================================
# Kubernetes Secret `quantlix-assistant` (namespace: quantlix) — key names
# =============================================================================
# Create / update (example):
#   kubectl create secret generic quantlix-assistant -n quantlix \
#     --from-literal=quantlix-api-key="YOUR_KEY" \
#     --from-literal=quantlix-deployment-id="YOUR_DEPLOYMENT_ID" \
#     --from-literal=database-url="postgresql://..." \
#     --from-literal=voyage-api-key="YOUR_VOYAGE_KEY" \
#     --dry-run=client -o yaml | kubectl apply -f -
#
# Optional keys (omit if unused):
#   --from-literal=quantlix-contract-id=support-bot
#   --from-literal=redis-url=redis://redis:6379/0
#
# Kebab-case keys above map to env vars QUANTLIX_API_KEY, QUANTLIX_DEPLOYMENT_ID,
# DATABASE_URL, VOYAGE_API_KEY, QUANTLIX_CONTRACT_ID, REDIS_URL in the Deployment.

# -----------------------------------------------------------------------------
# Optional in-cluster pgvector (Hetzner all-in setup)
# -----------------------------------------------------------------------------
# Base kustomize includes `infra/kubernetes/base/postgres/*` using image
# `pgvector/pgvector:pg16`, service:
#   quantlix-assistant-postgres.quantlix.svc.cluster.local:5432
#
# Create secret for Postgres credentials:
#   kubectl create secret generic quantlix-assistant-postgres -n quantlix \
#     --from-literal=username=postgres \
#     --from-literal=password='CHANGE_ME' \
#     --from-literal=database=quantlix_assistant \
#     --dry-run=client -o yaml | kubectl apply -f -
#
# Then set `database-url` in secret `quantlix-assistant` to:
#   postgresql://postgres:CHANGE_ME@quantlix-assistant-postgres.quantlix.svc.cluster.local:5432/quantlix_assistant
