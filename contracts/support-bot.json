{
  "comment_block": [
    "Quantlix Assistant contract.",
    "This pipeline lock enforces strict input/output schemas and binds runtime policy refs.",
    "Violations are blocked and logged before provider inference."
  ],
  "pipeline_lock": {
    "contract_version": "1.0",
    "mode": "enforce",
    "schema": {
      "strict": true,
      "input_schema": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string",
            "minLength": 3,
            "maxLength": 2000
          },
          "session_id": {
            "type": "string",
            "format": "uuid"
          },
          "history": {
            "type": "array",
            "maxItems": 20,
            "items": {
              "type": "object",
              "properties": {
                "role": {
                  "type": "string"
                },
                "content": {
                  "type": "string"
                }
              },
              "required": [
                "role",
                "content"
              ],
              "additionalProperties": false
            }
          },
          "messages": {
            "type": "array",
            "maxItems": 2,
            "items": {
              "type": "object",
              "properties": {
                "role": {
                  "type": "string"
                },
                "content": {
                  "type": "string"
                }
              },
              "required": [
                "role",
                "content"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "question",
          "session_id"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "answer": {
            "type": "string",
            "maxLength": 4000
          },
          "citations": {
            "type": "array",
            "minItems": 0,
            "items": {
              "type": "object",
              "properties": {
                "doc_id": {
                  "type": "string"
                },
                "anchor": {
                  "type": "string"
                },
                "snippet": {
                  "type": "string"
                }
              },
              "required": [
                "doc_id",
                "anchor",
                "snippet"
              ],
              "additionalProperties": false
            }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "out_of_scope": {
            "type": "boolean"
          }
        },
        "required": [
          "answer",
          "citations",
          "confidence",
          "out_of_scope"
        ],
        "additionalProperties": false
      }
    },
    "policies": {
      "actions": {
        "on_violation": "block_and_log",
        "include_violation_context": true
      },
      "policy_refs": [
        "scope-enforcement",
        "jailbreak-prevention",
        "pii-redaction",
        "budget-per-session",
        "rate-limit-per-ip"
      ]
    }
  },
  "sample_input": {
    "question": "How do I add a policy to a deployment?",
    "session_id": "7f9efe61-bfec-4bd4-a809-9a3ad06e3bd6",
    "history": [
      {
        "role": "user",
        "content": "I already have enforce mode enabled."
      }
    ],
    "messages": [
      {
        "role": "system",
        "content": "You are Quantlix Assistant. Answer only questions about Quantlix."
      },
      {
        "role": "user",
        "content": "How do I add a policy to a deployment?"
      }
    ]
  },
  "sample_output": {
    "answer": "Attach the policy to your deployment config, publish a new revision, and verify enforcement events for the next request.",
    "citations": [
      {
        "doc_id": "docs/contracts/README.md",
        "anchor": "add-policies-to-deployment",
        "snippet": "Attach policy refs in pipeline_lock and publish a revision."
      }
    ],
    "confidence": 0.92,
    "out_of_scope": false
  }
}
