{
  "name": "quantlix-assistant-widget",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:chat": "vite --open /chat.html",
    "dev:react": "vite --open /react-demo.html",
    "dev:assistant": "vite --open /index.html",
    "build": "vite build && vite build --config vite.lib.config.ts",
    "build:lib": "vite build --config vite.lib.config.ts",
    "preview": "vite preview"
  },
  "exports": {
    "./chat": {
      "types": "./src/chat/index.ts",
      "import": "./dist/lib/quantlix-chat.js"
    },
    "./chat.css": "./src/chat/chat.css",
    "./chat/style.css": "./dist/lib/style.css"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.1",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
